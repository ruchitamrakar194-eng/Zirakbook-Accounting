  companyId       Int
  transactionType String // e.g., "invoice", "receipt", "purchaseorder", "salesreturn", etc.
  prefix          String?  @default("")
  currentNumber   Int      @default(0)
  paddingLength   Int      @default(4)
  pattern         String   @default("numeric") // "numeric", "alphanumeric", or "custom"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  company         company  @relation(fields: [companyId], references: [id], onDelete: Cascade, map: "TransactionNumbering_companyId_fkey")

  @@unique([companyId, transactionType], map: "TransactionNumbering_companyId_transactionType_key")
  @@index([companyId], map: "TransactionNumbering_companyId_fkey")
}

model auditlog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  userEmail String?
  userName  String?
  action    String // "CREATE", "UPDATE", "DELETE"
  entity    String // "Invoice", "PurchaseBill", "Receipt", "Payment", "Voucher", "Customer", "Vendor", "Product", "POS"
  entityId  Int?
  details   String?  @db.Text
  companyId Int
  createdAt DateTime @default(now())

  user    user?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  company company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
}
